# Sao chép file này thành `.env.local` và điền giá trị thật.
# KHÔNG commit `.env.local`.

# --- Frontend (Vite expose biến có tiền tố VITE_) ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Site key của Cloudflare Turnstile (public, an toàn để expose)
VITE_TURNSTILE_SITE_KEY=

# --- Chỉ dùng local: script ingest + Edge Function secrets ---
# TUYỆT ĐỐI không đặt tiền tố VITE_ cho các key này (sẽ lộ ra client).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Salt để hash IP (random 32 bytes, ví dụ: openssl rand -hex 32)
IP_HASH_SALT=
